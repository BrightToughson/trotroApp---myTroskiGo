{
  "outputDirectory": "dist",
  "routes": [
    { "src": "/assets/(.*)", "headers": { "cache-control": "public, max-age=31536000, immutable" }, "continue": true },
    { "src": "/(.*)\\.(ttf|woff|woff2|png|jpg|jpeg|gif|svg|ico|json|webp)$", "continue": true },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
