{
  "short_name": "myTroski Go",
  "name": "myTroski Go",
  "description": "Your ultimate transit companion for Trotro travel in Ghana.",
  "icons": [
    {
      "src": "/logo/mytroskigo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
