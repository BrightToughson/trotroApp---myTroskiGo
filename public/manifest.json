  "screenshots": [
    {
      "src": "/assets/screenshots/home.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home Screen of myTroski Go"
    },
    {
      "src": "/assets/screenshots/find_ride.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Planning a journey"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+trotro",
