{
  "expo": {
    "name": "myTroski Go",
    "slug": "TrotroApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/mytroskigo.png",
    "scheme": "trotroapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trotroapp.mytroskigo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Allow myTroski Go to use your location to find nearby trotro stops and plan your journey.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow myTroski Go to use your location to provide real-time updates even when the app is in the background.",
        "NSCameraUsageDescription": "Allow myTroski Go to access your camera to take photos for community alerts.",
        "NSPhotoLibraryUsageDescription": "Allow myTroski Go to access your photos to upload community alerts."
      }
    },
    "android": {
      "package": "com.trotroapp.mytroskigo",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/mytroski_foreground.png",
        "backgroundImage": "./assets/logo/mytroski_background.png",
        "monochromeImage": "./assets/logo/mytroski_monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/logo/mytroskigo_favicon.png",
      "bundler": "metro",
      "name": "myTroski Go",
      "shortName": "myTroski Go",
      "themeColor": "#111827",
      "backgroundColor": "#111827",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      [
        "@rnmapbox/maps/app.plugin.js",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/mytroskigo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea8f1eed-c610-407c-be8e-0523e4c2c3aa"
      }
    },
    "owner": "toughson"
  }
}
